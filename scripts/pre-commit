#!/bin/bash

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$')

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

if ! command -v swiftformat &> /dev/null; then
  echo "error: swiftformat not installed. Install with: brew install swiftformat"
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"
VERSION_FILE="$REPO_ROOT/.swiftformat-version"
if [ -f "$VERSION_FILE" ]; then
  EXPECTED=$(tr -d '[:space:]' < "$VERSION_FILE")
  LOCAL=$(swiftformat --version)
  if [ "$LOCAL" != "$EXPECTED" ]; then
    echo "warning: swiftformat version mismatch (local: $LOCAL, expected: $EXPECTED)"
    echo "  Run: brew install swiftformat"
    echo ""
  fi
fi

if ! swiftformat --lint $STAGED_FILES; then
  echo ""
  echo "Fix with: swiftformat ."
  exit 1
fi
